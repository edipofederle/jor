{:source-paths ["src"]
 :dependencies [[reagent "1.2.0"]
                [re-frame "1.4.0"]]
 :dev-http {8080 "public"}
 :builds
 {:app {:target     :browser
        :output-dir "public/js"
        :asset-path "/js"
        :modules    {:main {:entries [jor.core]}}
        :devtools   {:after-load jor.core/on-reload
                     :init-fn    jor.core/main}}}}
